; .
; ↳↳var_glyph_scratch_template[0x02 + i * 0x02] = DE_src[i]
; .
; ↳fn_routine_8_byte_screen_blit_primitive(DE_src=var_glyph_scratch_template,
; B_row=B_row, C_col=C_col)
; .
; ↳fn_routine_8_byte_screen_blit_primitive(DE_src=var_glyph_scratch_template +
; 0x08, B_row=B_row + 0x01, C_col=C_col)
