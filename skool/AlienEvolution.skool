 $FC73 DEC L         ;
 $FC74 JP Z,$FC61    ;
; This entry point is used by the routine at #R$FC13.
*$FC77 OUT ($FE),A   ;
 $FC79 NOP           ;
 $FC7A NOP           ;
 $FC7B DJNZ $FC51    ;
 $FC7D INC C         ;
 $FC7E JP NZ,$FC53   ;
