; fn_input_patch_writer_apply
;
; Input-patch writer entry: stores opcode bytes to 0xE0C6/0xE0D0/0xE0DA/0xE0E4
; and tail byte to 0xE0EE.
;
; .
;
; Args: A_op is u8 opcode byte for four branch sites in key-scan template;
; D_tail is u8 opcode byte for call-condition site.
; .
; Returns: none.
; .
; def fn_input_patch_writer_apply(A_op, D_tail):
; .
; ↳patch_control_scan_slot_3_branch_opcode = A_op
; .
; ↳patch_control_scan_slot_4_branch_opcode = A_op
; .
; ↳patch_control_scan_slot_1_branch_opcode = A_op
; .
; ↳patch_control_scan_slot_2_branch_opcode = A_op
; .
; ↳patch_control_scan_slot_5_action_opcode = D_tail
@label=fn_input_patch_writer_apply
c$7143 LD ($E0D0),A  ;
 $7146 LD ($E0C6),A  ;
 $7149 LD ($E0DA),A  ;
 $714C LD ($E0E4),A  ;
 $714F LD A,D        ;
 $7150 LD ($E0EE),A  ;
 $7153 RET           ;

; const_panel_source_padding_byte
