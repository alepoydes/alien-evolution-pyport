 $A88F LD DE,$AE72   ;
 $A892 LD HL,$A66F   ;
*$A895 LD A,(HL)     ;
 $A896 CP $E6        ;
 $A898 JR Z,$A89D    ;
 $A89A INC HL        ;
 $A89B JR $A895      ;
*$A89D INC HL        ;
 $A89E INC HL        ;
 $A89F LD A,(HL)     ;
 $A8A0 CP $F6        ;
 $A8A2 JR NZ,$A895   ;
 $A8A4 DEC HL        ;
 $A8A5 LD A,(DE)     ;
