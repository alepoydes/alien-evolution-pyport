; fn_process_transient_effect_queues_core
;
; Transient-effect queue processor core entry: scans three 10-slot queues and
; dispatches per-queue handlers.
;
; .
;
; Args: HL_queue is ptr_u8 queue entries base (10 triplets
; [state,ptr_lo,ptr_hi]); DE_handler is ptr_fn callback(A_state:u8,
; HL_cell:ptr_u8)->A_state_next:u8.
; .
; Returns: none.
; .
; def fn_process_transient_effect_queues_core(HL_queue, DE_handler):
; .
; ↳patch_transient_queue_handler_call_target = DE_handler
; .
; ↳for _ in range(0x0A):
; .
; ↳↳A_state = HL_queue[0x00]
; .
; ↳↳if A_state != 0x00:
; .
; ↳↳↳HL_cell = ptr_u16(HL_queue[0x01], HL_queue[0x02])
; .
; ↳↳↳A_state = callback(DE_handler, A_state=A_state, HL_cell=HL_cell)
; .
; ↳↳↳HL_queue[0x00] = A_state
; .
; ↳↳↳HL_queue[0x01], HL_queue[0x02] = split_u16(HL_cell)
; .
; ↳↳HL_queue += 0x03
; .
; 0xE4BE is the CALL target word inside this routine (CALL nn at 0xE4BD),
; runtime-written from DE at 0xE4AC.
@label=fn_process_transient_effect_queues_core
c$E4AC LD ($E4BE),DE ;
 $E4B0 LD B,$0A      ;
*$E4B2 LD A,(HL)     ;
 $E4B3 OR A          ;
 $E4B4 JR Z,$E4C7    ;
 $E4B6 LD A,(HL)     ;
 $E4B7 INC HL        ;
 $E4B8 LD E,(HL)     ;
 $E4B9 INC HL        ;
 $E4BA LD D,(HL)     ;
 $E4BB EX DE,HL      ;
 $E4BC PUSH DE       ;
 $E4BD CALL $E530    ;
 $E4C0 POP DE        ;
 $E4C1 EX DE,HL      ;
 $E4C2 LD (HL),D     ;
 $E4C3 DEC HL        ;
 $E4C4 LD (HL),E     ;
 $E4C5 DEC HL        ;
 $E4C6 LD (HL),A     ;
*$E4C7 INC HL        ;
 $E4C8 INC HL        ;
 $E4C9 INC HL        ;
 $E4CA DJNZ $E4B2    ;
 $E4CC RET           ;

