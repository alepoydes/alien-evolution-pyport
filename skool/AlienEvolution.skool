; .
; ↳SP += 0x0004
; .
; ↳enable_interrupts()
; .
; ↳return
@label=forced_interpreter_abort_path
c$FC0B POP HL        ;
 $FC0C POP HL        ;
 $FC0D EI            ;
 $FC0E RET           ;

