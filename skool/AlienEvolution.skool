; const_control_icon_set_table
;
; Control-icon sets #1..#6 (192 bytes total at 0x69E6-0x6AA5), consumed by
; drawer 0x6CD8 via selector stubs 0x6EAA..0x6EC8.
; .
; Storage format per icon set (32 bytes => 16x16): left half (16 bytes, 8x16)
; followed by right half (16 bytes, 8x16); each byte is one row (bit7 leftmost
; pixel, bit0 rightmost), rows ordered top->bottom.
; .
; Equivalent 8x8-quadrant assembly order is [1 2; 4 3]: (base+0, base+16,
; base+8, base+24).
; .
; Set starts: #1 0x69E6 (overlaps windows 84..87), #2 0x6A06 (88..91), #3
; 0x6A26 (92..95), #4 0x6A46 (96..99), #5 0x6A66, #6 0x6A86.
; .
; In text paths, code 96 (<SYM60>) uses 0x6A46-0x6A4D from set #4 and appears
; in menu streams 0x6C19/0x6C25/0x6C35/0x6C41/0x6C4B/0x6C5A.
; .
; #HTML(<style>.control_icons
; td{white-space:nowrap;vertical-align:middle;}.control_icons
; img{image-rendering:pixelated;}</style>
; )#TABLE(control_icons)
; { =h Icon | =h 16x16 preview }
; #FOR1,6,1/^%I%^{ #N(%I%,1) |
; #UDGARRAY2,56,4,1,0((27110+(%I%-1)*32+0)-(27110+(%I%-1)*32+0);(27110+(%I%-1)*32+16)-(27110+(%I%-1)*32+16);(27110+(%I%-1)*32+8)-(27110+(%I%-1)*32+8);(27110+(%I%-1)*32+24)-(27110+(%I%-1)*32+24))(control_icon_%I%|Control
; icon #%I% assembled as [1 2;4 3]) }
; ^ ^/TABLE#
; .
; Structure: 6 icon records x 32 bytes; each record is [left_half_8x16 (16
; bytes), right_half_8x16 (16 bytes)].
@label=const_control_icon_set_table
b$69E6 DEFB $00,$40,$60,$71,$7B,$7F,$7F,$7F
 $69EE DEFB $7F,$7F,$7F,$7F,$7F,$7F,$7F,$00
 $69F6 DEFB $30,$78,$FC,$FE,$FF,$FF,$FE,$FC
 $69FE DEFB $F8,$F0,$E0,$F0,$F8,$FC,$FE,$00
