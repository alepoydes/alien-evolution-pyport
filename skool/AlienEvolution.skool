; interpreter_inner_loop_branch_helper_timing
;
; Interpreter inner-loop branch helper for timing/output cycle (paired with
; self-modifying loop at 0xFC11).
;
; .
;
; Args: A_main is u8 current beeper latch value; A_alt is u8 alternate latch
; value; E_ctr/E_reload are fast-divider bytes passed through unchanged in this
; FC70 path; L_ctr/L_reload are slow-divider counter/reload bytes; B_phase is
; u8 inner-loop counter; C_cycles is u8 outer-loop counter; toggle_mask is u8
; XOR mask.
; .
; Returns: updated tuple (A_main, A_alt, E_ctr, L_ctr, B_phase, C_cycles).
; .
; def interpreter_inner_loop_branch_helper_timing(A_main, A_alt, E_ctr,
; E_reload, L_ctr, L_reload, B_phase, C_cycles, toggle_mask):
; .
; ↳# NOTE: entry byte JR Z,$FC70 is timing padding on normal FC57->FC70 path (Z
; is clear).
; .
; ↳A_main, A_alt = A_alt, A_main
; .
; ↳L_ctr = (L_ctr - 0x01) & 0xFF
; .
; ↳if L_ctr == 0x00:
; .
; ↳↳out_port_0xFE(A_main)
; .
; ↳↳L_ctr = L_reload
; .
; ↳↳A_main ^= toggle_mask
; .
; ↳else:
; .
; ↳↳out_port_0xFE(A_main)
; .
; ↳B_phase = (B_phase - 0x01) & 0xFF
; .
; ↳if B_phase != 0x00:
; .
; ↳↳return A_main, A_alt, E_ctr, L_ctr, B_phase, C_cycles
; .
; ↳C_cycles = (C_cycles + 0x01) & 0xFF
; .
; ↳return A_main, A_alt, E_ctr, L_ctr, B_phase, C_cycles
@label=interpreter_inner_loop_branch_helper_timing
