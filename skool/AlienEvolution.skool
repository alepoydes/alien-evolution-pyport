; fn_repeat_wrapper_xe600
;
; Repeat wrapper for 0xE600: rerun while nonzero, non-bit7 state is returned.
;
; .
;
; Args: A_state is u8 queue-slot state byte; HL_cell is ptr_u8 target map cell.
; .
; Returns: A_state_next is u8 next queue-slot state after repeated E600 passes.
; .
; def fn_repeat_wrapper_xe600(A_state, HL_cell):
; .
; ↳A_state = transient_queue_c_state_machine_core(A_state=A_state,
; HL_cell=HL_cell)
; .
; ↳while A_state != 0x00 and (A_state & 0x80) == 0x00:
; .
; ↳↳A_state = transient_queue_c_state_machine_core(A_state=A_state,
; HL_cell=HL_cell)
; .
; ↳return A_state
