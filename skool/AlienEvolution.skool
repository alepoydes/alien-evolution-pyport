; fn_stream_byte_fetch_helper
;
; Stream byte fetch helper: advance pointer pair, load next byte, and branch to
; abort on 0x40 terminator.
;
; .
;
; Args: HL_ptr points to 16-bit little-endian stream pointer [ptr_lo, ptr_hi].
; .
; Returns: A_byte is next stream byte; HL_ptr is updated to the incremented
; stream pointer.
; .
; def fn_stream_byte_fetch_helper(HL_ptr):
; .
; ↳DE_ptr = HL_ptr[0x00] | (HL_ptr[0x01] << 0x08)
; .
; ↳DE_ptr += 0x0001
; .
; ↳A_byte = mem_u8(DE_ptr)
; .
; ↳if A_byte == 0x40:
; .
; ↳↳forced_interpreter_abort_path()
; .
; ↳HL_ptr[0x00] = DE_ptr & 0x00FF
; .
; ↳HL_ptr[0x01] = (DE_ptr >> 0x08) & 0x00FF
; .
; ↳return A_byte
@label=fn_stream_byte_fetch_helper
