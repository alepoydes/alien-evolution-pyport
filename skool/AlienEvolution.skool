; fn_patches_immediate_operands_routine_xa66f_sprite
;
; Patches immediate operands in routine 0xA66F from sprite-table data bytes.
;
; .
;
; Args: none.
; .
; Returns: none.
; .
; def fn_patches_immediate_operands_routine_xa66f_sprite():
; .
; ↳DE_src = var_active_sprite_patch_source_ae72
; .
; ↳HL_scan = fn_frequent_cube_blit_fast_path
; .
; ↳for _ in range(0x20):
; .
; ↳↳while not (HL_scan[0x00] == 0xE6 and HL_scan[0x02] == 0xF6):
; .
; ↳↳↳HL_scan += 0x01
; .
; ↳↳HL_scan[0x01] = DE_src[0x00]
; .
; ↳↳HL_scan[0x03] = DE_src[0x01]
; .
; ↳↳DE_src += 0x02
; .
; ↳↳HL_scan += 0x03
@label=fn_patches_immediate_operands_routine_xa66f_sprite
