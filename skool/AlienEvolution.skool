; fn_helper_xa7fe
;
; Helper for 0xA7FE: advance floor-pattern pointer HL and load next pattern
; word into BC (C low byte, B high).
;
; .
;
; Args: HL_tbl is ptr_u8 floor-pattern cursor positioned on the current B-byte
; in a lane table.
; .
; Returns: HL_tbl advanced by 2 bytes; BC_lane is the next lane word (C low
; byte, B high byte).
; .
; def fn_helper_xa7fe(HL_tbl):
; .
; ↳HL_tbl += 0x01
; .
; ↳C_lane = HL_tbl[0x00]
; .
; ↳HL_tbl += 0x01
; .
; ↳B_lane = HL_tbl[0x00]
; .
; ↳return HL_tbl, B_lane, C_lane
@label=fn_helper_xa7fe
c$A854 INC HL        ;
 $A855 LD C,(HL)     ;
 $A856 INC HL        ;
 $A857 LD B,(HL)     ;
 $A858 RET           ;

