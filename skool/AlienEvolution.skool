; viewport_strip_blit_core
;
; Viewport strip blit core: copies rendered strips to ZX bitmap window with ZX
; row-layout stepping.
;
; .
;
; Self-mod patch points inside this code block:
; 0xA5C8/0xA5DB/0xA5EE/0xA601/0xA614/0xA627/0xA63A/0xA64D are immediate words
; in LD HL,nn; they are written by 0xA818..0xA849.
; .
; Args: HL_src is ptr_u8 linear viewport source row (normally
; var_linear_viewport_work_buffer); DE_dst is ptr_u8 ZX bitmap destination base
; (normally 0x4021); A_passes is u8 outer pass count (normally 2).
; .
; Returns: none.
; .
; def viewport_strip_blit_core(HL_src, DE_dst, A_passes):
; .
; ↳for _ in range(A_passes):
; .
; ↳↳copy_26_byte_strips_into_zx_layout(HL_src=HL_src, DE_dst=DE_dst)
; .
; ↳fill_linear_viewport_stack_window_via_sp_switch()
@label=viewport_strip_blit_core
