; fn_stream_byte_fetch_helper(HL_ptr=var_stream_ptr_c_lo)
; .
; ↳HL_t1, E_cmd1 =
; fn_timing_parameter_decode_helper(HL_cmd=var_stream_interpreter_state + 0x00)
; .
; ↳if E_cmd1 & 0x80:
; .
; ↳↳special_command_dispatcher(A_cmd=var_stream_interpreter_state[0x00])
; .
; ↳↳return
; .
; ↳HL_t2, _ =
; fn_timing_parameter_decode_helper(HL_cmd=var_stream_interpreter_state + 0x01)
; .
; ↳if high_byte(HL_t2) == 0x01 and high_byte(HL_t1) == 0x01:
