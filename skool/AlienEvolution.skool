; .
; ↳↳return
; .
; ↳if A_new >= C_old:
; .
; ↳↳HL_bar[A_new] = B_fill
; .
; ↳↳return
; .
; ↳if A_new != 0x00:
; .
; ↳↳HL_bar[A_new] = B_fill
; .
; ↳HL_bar[A_new + 0x01] = 0x00
