; var_highscore_edit_row_ptr
;
; Pointer to current editable high-score row stream, consumed by LD HL,(0x7110)
; before CALL 0xEAE2 at 0x7070.
; .
; Structure: 16-bit little-endian pointer field [ptr_lo, ptr_hi].
@label=var_highscore_edit_row_ptr
b$7110 DEFB $00,$00

; var_highscore_name_edit_state
;
; Name-entry redraw scratch byte adjacent to pointer 0x7110.
; .
; Structure: 1-byte high-score name-entry scratch/state value.
@label=var_highscore_name_edit_state
b$7112 DEFB $00

; str_name_entry_prompt_stream
;
; Name-entry prompt stream for 0xEAE2.
; .
; Decoded text stream: "ENTER YOUR NAME".
@label=str_name_entry_prompt_stream
t$7113 DEFM "%.4%2",$00,"9/52",$00,".!-%",$FF

; fn_front_end_two_step_beeper_cadence
;
; Front-end two-step beeper cadence helper (two ROM 0x03B5 calls used for menu
; pacing).
;
; .
;
; Args: none.
; .
; Returns: none.
; .
; def fn_front_end_two_step_beeper_cadence():
; .
; ↳rom_beeper(DE_ticks=0x0032, HL_period=0x0032)
; .
; ↳rom_beeper(DE_ticks=0x0064, HL_period=0x0064)
@label=fn_front_end_two_step_beeper_cadence
c$7123 LD HL,$0032   ;
 $7126 LD DE,$0032   ;
 $7129 CALL $03B5    ;
 $712C LD HL,$0064   ;
 $712F LD DE,$0064   ;
 $7132 JP $03B5      ;

; fn_input_patch_preset
;
; Input patch preset (D=0xC4, A=0xC2): apply joystick/keyboard opcode bytes
; then jump to shared tail 0x6E36.
;
; .
;
; Args: none.
; .
; Returns: none.
; .
; def fn_input_patch_preset():
; .
; ↳fn_input_patch_writer_apply(A_op=0xC2, D_tail=0xC4)
; .
; ↳fn_input_opcode_patch_tail()
@label=fn_input_patch_preset
c$7135 LD D,$C4      ;
 $7137 LD A,$C2      ;
 $7139 CALL $7143    ;
 $713C JP $6E36      ;

; fn_input_patch_preset_2
;
