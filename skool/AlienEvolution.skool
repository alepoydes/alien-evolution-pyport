; ↳↳fn_low_level_tone_delay_primitive(HL_delay=HL_delay)
; .
; ↳↳HL_delay = adc16(HL_delay, 0x00FF)  # carry comes from prior tone path
; flags
@label=lookup_driven_burst_generator
c$FD4B LD E,B        ;
 $FD4C LD D,$00      ;
 $FD4E LD HL,$FD83   ;
 $FD51 ADC HL,DE     ;
 $FD53 LD A,(HL)     ;
 $FD54 LD B,A        ;
 $FD55 LD HL,$0003   ;
*$FD58 PUSH BC       ;
 $FD59 LD DE,$0001   ;
 $FD5C PUSH HL       ;
 $FD5D CALL $FD6A    ;
 $FD60 POP HL        ;
 $FD61 LD DE,$00FF   ;
 $FD64 ADC HL,DE     ;
 $FD66 POP BC        ;
 $FD67 DJNZ $FD58    ;
 $FD69 RET           ;

; fn_low_level_tone_delay_primitive
;
; Low-level tone delay primitive: select ROM timing variant and invoke sound
; helper at 0x03D4.
;
; .
;
; Args: HL_delay is u16 delay/tone code (only L byte is used for variant
; index).
; .
; Returns: none (IFF is cleared by DI before RET).
; .
; def fn_low_level_tone_delay_primitive(HL_delay):
; .
; ↳C_variant = (~(HL_delay & 0x00FF)) & 0x03
; .
; ↳IX_rom_tone_entry = 0x03D1 + C_variant
; .
; ↳A_tone = var_stream_cmd_byte_2
; .
; ↳rom_tone_03D4(IX_rom_tone_entry=IX_rom_tone_entry, A_tone=A_tone)
; .
; ↳disable_interrupts()
@label=fn_low_level_tone_delay_primitive
c$FD6A LD A,L        ;
 $FD6B SRL L         ;
 $FD6D SRL L         ;
 $FD6F CPL           ;
 $FD70 AND $03       ;
 $FD72 LD C,A        ;
 $FD73 LD B,$00      ;
 $FD75 LD IX,$03D1   ;
 $FD79 ADD IX,BC     ;
 $FD7B LD A,($FBE6)  ;
 $FD7E CALL $03D4    ;
 $FD81 DI            ;
 $FD82 RET           ;

