; fn_transient_queue_handler_core
;
; Transient queue-A handler core (0xE530): classify target cell and emit
; state/result for queue slot update.
;
; .
;
; Args: A_state is u8 queue-slot state byte; HL_cell is ptr_u8 target map cell
; from queue entry.
; .
; Returns: A_state_next is u8 queue-slot state result written back by queue
; dispatcher.
; .
; def fn_transient_queue_handler_core(A_state, HL_cell):
; .
; ↳A_state &= 0x7F
; .
; ↳if (A_state & 0xFE) != 0x00:
; .
; ↳↳return countdown_phase_helper(HL_cell=HL_cell, stack_A_state=A_state)
; .
; ↳A_code = HL_cell[0x00] & 0x3F
; .
; ↳if A_code == 0x34 or A_code == 0x35:
; .
; ↳↳return state_toggle_helper(HL_cell=HL_cell, D_base=0x34,
; stack_A_state=A_state)
; .
; ↳if A_code == 0x38 or A_code == 0x00:
; .
; ↳↳return immediate_mark_helper(HL_cell=HL_cell, stack_A_state=A_state)
; .
; ↳if A_code < 0x0D:
; .
; ↳↳return return_helper(stack_A_state=A_state)
; .
; ↳HL_cell[0x00] = (HL_cell[0x00] & 0xC0) | 0x38
; .
; ↳fn_neighbor_tag_helper_queue_b_handlers(HL_cell=HL_cell)
; .
; ↳return 0x00
@label=fn_transient_queue_handler_core
c$E530 RES 7,A       ;
 $E532 PUSH AF       ;
 $E533 LD D,$34      ;
 $E535 AND $FE       ;
 $E537 JR NZ,$E5A1   ;
 $E539 LD A,(HL)     ;
 $E53A AND $3F       ;
 $E53C CP D          ;
 $E53D JR Z,$E58D    ;
 $E53F CP $35        ;
 $E541 JR Z,$E58D    ;
 $E543 CP $38        ;
 $E545 JR Z,$E5B7    ;
 $E547 OR A          ;
 $E548 JR Z,$E5B7    ;
 $E54A CP $0D        ;
 $E54C JR C,$E5C7    ;
 $E54E LD A,$C0      ;
 $E550 AND (HL)      ;
 $E551 OR $38        ;
 $E553 LD (HL),A     ;
 $E554 CALL $E55A    ;
 $E557 POP AF        ;
 $E558 XOR A         ;
 $E559 RET           ;

