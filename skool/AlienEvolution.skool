 $FD02 SRA A         ;
 $FD04 SRA A         ;
 $FD06 LD E,A        ;
 $FD07 CP $00        ;
 $FD09 JR NZ,$FD0C   ;
 $FD0B INC E         ;
*$FD0C POP AF        ;
 $FD0D RET           ;

