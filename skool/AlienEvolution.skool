; .
; ↳A_alt = var_stream_interpreter_state[0x02]
; .
; ↳E_ctr = low_byte(HL_t1)
; .
; ↳E_reload = high_byte(HL_t1)
; .
; ↳L_ctr = low_byte(HL_t2)
; .
; ↳L_reload = high_byte(HL_t2)
; .
; ↳toggle_mask = 0x10
; .
; ↳while True:
; .
; ↳↳# NOTE: cycle-accurate timing is implemented by the shared FC51<->FC70 loop
; and retained as ASM.
; .
; ↳↳A_main, A_alt, E_ctr, L_ctr, B_phase, C_cycles =
; interpreter_inner_loop_branch_helper_timing(A_main=A_main, A_alt=A_alt,
; E_ctr=E_ctr, E_reload=E_reload, L_ctr=L_ctr, L_reload=L_reload,
; B_phase=B_phase, C_cycles=C_cycles, toggle_mask=toggle_mask)
