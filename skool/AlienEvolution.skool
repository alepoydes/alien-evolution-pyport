; control_icon_drawer
;
; Control-icon drawer: consume one 32-byte icon set at DE (16-byte left half +
; 16-byte right half), decode bits to 0/148 attribute writes, and stamp
; resulting 16x16 icon into attribute area at 0x5908/0x5910.
;
; .
;
; Args: DE_icon is ptr_u8 icon payload (32 bytes = two 16-byte halves).
; .
; Returns: DE_icon advanced by 32 bytes.
; .
; def control_icon_drawer(DE_icon):
; .
; ↳fn_control_icon_row_draw_loop(HL_dst=0x5908, DE_src=DE_icon[0x00:0x10])
; .
; ↳fn_control_icon_row_draw_loop(HL_dst=0x5910, DE_src=DE_icon[0x10:0x20])
@label=control_icon_drawer
c$6CD8 LD HL,$5908   ;
 $6CDB CALL $6CE1    ;
 $6CDE LD HL,$5910   ;

; fn_control_icon_row_draw_loop
;
; Control-icon drawer row-loop entry: processes 16 rows x 8 bits and writes
; 0/0x94 attribute pixels.
;
; .
;
; Args: HL_dst is ptr_u8 to top-left destination of one 8x16 icon half in
; attribute RAM; DE_src is ptr_u8 to 16 source row bytes (bit7 is leftmost
; pixel).
; .
; Returns: none.
; .
; def fn_control_icon_row_draw_loop(HL_dst, DE_src):
; .
; ↳for _ in range(0x10):
; .
; ↳↳A_bits = DE_src[0x00]
; .
; ↳↳for _ in range(0x08):
; .
; ↳↳↳HL_dst[0x00] = 0x94 if (A_bits & 0x80) else 0x00
; .
; ↳↳↳A_bits = ((A_bits << 1) & 0xFF) | (A_bits >> 7)
; .
; ↳↳↳HL_dst += 1
; .
; ↳↳DE_src += 1
; .
; ↳↳HL_dst += 0x18
@label=fn_control_icon_row_draw_loop
c$6CE1 LD B,$10      ;
*$6CE3 PUSH BC       ;
 $6CE4 LD B,$08      ;
 $6CE6 LD A,(DE)     ;
*$6CE7 RLCA          ;
 $6CE8 JR C,$6CEE    ;
 $6CEA LD (HL),$00   ;
 $6CEC JR $6CF0      ;
*$6CEE LD (HL),$94   ;
*$6CF0 INC HL        ;
 $6CF1 DJNZ $6CE7    ;
 $6CF3 INC DE        ;
 $6CF4 PUSH DE       ;
 $6CF5 LD DE,$0018   ;
 $6CF8 ADD HL,DE     ;
 $6CF9 POP DE        ;
 $6CFA POP BC        ;
 $6CFB DJNZ $6CE3    ;
 $6CFD RET           ;

; const_define_keys_descriptor_table
;
; Define-keys descriptor table at 0x6CFE-0x6D0F (6 slots): per-slot keyboard
; port pair + mask bytes captured in 0x6E48 setup.
; .
; Slot writes in 0x6E4C flow: (0x6CFE,0x6D06), (0x6D00,0x6D07),
; (0x6D04,0x6D09), (0x6D02,0x6D08), (0x6D0A,0x6D0C), (0x6D0D,0x6D0F).
; .
; Structure: six control descriptors encoded as interleaved
; (port_lo,port_hi,mask) fields across 0x6CFE-0x6D0F; consumed by
; copier/patcher at 0x6D10.
@label=const_define_keys_descriptor_table
