; fn_compact_8x8_text_renderer
;
; Compact 8x8 text renderer: read byte codes at HL until 0xFF, map code C to
; glyph window 0x66BE+8*(C+1), and blit one 8-row cell via 0xEAA6.
;
; .
;
; Args: none (uses fixed source stream str_byline_stream and fixed cursor
; row/column 0x17/0x01).
; .
; Returns: none.
; .
; def fn_compact_8x8_text_renderer():
; .
; ↳HL_stream = str_byline_stream
; .
; ↳const_highscore_header_tail_word = HL_stream
; .
; ↳B_row, C_col = 0x17, 0x01
; .
; ↳while True:
; .
; ↳↳A_code = HL_stream[0x00]
; .
; ↳↳if A_code == 0xFF:
; .
; ↳↳↳break
; .
; ↳↳DE_glyph = 0x66BE + ((A_code + 0x01) << 0x03)
; .
; ↳↳fn_routine_8_byte_screen_blit_primitive(DE_src=DE_glyph, B_row=B_row,
; C_col=C_col)
; .
; ↳↳C_col += 0x01
; .
; ↳↳HL_stream = const_highscore_header_tail_word + 0x0001
; .
; ↳↳const_highscore_header_tail_word = HL_stream
; .
; ↳mem[0x5AE0:0x5B00] = 0x04
@label=fn_compact_8x8_text_renderer
c$6BAD LD HL,$6C63   ;
 $6BB0 LD ($6FBA),HL ;
 $6BB3 LD BC,$1701   ;
*$6BB6 LD A,(HL)     ;
 $6BB7 CP $FF        ;
 $6BB9 JR Z,$6BD6    ;
 $6BBB PUSH BC       ;
 $6BBC INC A         ;
 $6BBD LD B,A        ;
 $6BBE LD HL,$66BE   ;
 $6BC1 LD DE,$0008   ;
*$6BC4 ADD HL,DE     ;
 $6BC5 DJNZ $6BC4    ;
 $6BC7 EX DE,HL      ;
 $6BC8 POP BC        ;
 $6BC9 CALL $EAA6    ;
 $6BCC INC C         ;
 $6BCD LD HL,($6FBA) ;
 $6BD0 INC HL        ;
 $6BD1 LD ($6FBA),HL ;
 $6BD4 JR $6BB6      ;
*$6BD6 LD HL,$5AE0   ;
 $6BD9 LD DE,$5AE1   ;
 $6BDC LD (HL),$04   ;
 $6BDE LD BC,$001F   ;
 $6BE1 LDIR          ;
 $6BE3 RET           ;

