; .
; ↳disable_interrupts()
; .
; ↳var_renderer_fill_counters = 0x250E
; .
; ↳HL_map = read_u16(var_runtime_current_cell_ptr_lo)
; .
; ↳BC_row_col = var_current_map_coords
; .
; ↳build_visible_cell_staging_lattice(HL_map=HL_map, BC_row_col=BC_row_col,
; DE_dst=var_visible_cell_staging_lattice)
; .
; ↳var_renderer_staging_cursor_ptr = var_visible_cell_staging_lattice
; .
; ↳render_staging_to_cell_buffer(HL_stage=var_visible_cell_staging_lattice,
; DE_dst=var_cell_blit_work_buffer)
; .
; ↳viewport_strip_blit_core(HL_src=var_linear_viewport_work_buffer,
; DE_dst=0x4021, A_passes=0x02)
; .
; ↳# Dispatch order per staged cell is fixed: 23/87/215/151 -> bit6 -> bit7 ->
; generic sprite.
