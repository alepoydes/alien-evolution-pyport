; ↳B_delay = A_inv
; .
; ↳C_delay = A_inv
; .
; ↳E_wait = sra8(sra8((A_inv + 0x01) & 0xFF))
; .
; ↳if E_wait == 0x00:
; .
; ↳↳E_wait = 0x01
