 $FBF1 INC HL        ;
 $FBF2 LD D,(HL)     ;
 $FBF3 INC DE        ;
 $FBF4 LD A,(DE)     ;
 $FBF5 CP $40        ;
 $FBF7 JR Z,$FC0B    ;
 $FBF9 LD (HL),D     ;
 $FBFA DEC HL        ;
 $FBFB LD (HL),E     ;
 $FBFC RET           ;

; fn_timing_parameter_decode_helper
;
; Timing/parameter decode helper: map command byte to value from table
; 0xFCA0+12*n.
;
; .
;
; Args: HL_cmd points to one command byte from var_stream_cmd_byte_1 or
; var_stream_cmd_byte_2.
; .
; Returns: HL_timing is (table_hi << 8) | 0x01 where table_hi comes from
; const_stream_timing_profile_table[E_idx]; E_idx is (cmd + 0x0C) & 0xFF.
; .
; def fn_timing_parameter_decode_helper(HL_cmd):
; .
; ↳E_idx = (HL_cmd[0x00] + 0x0C) & 0xFF
; .
; ↳table_hi = const_stream_timing_profile_table[E_idx]
; .
; ↳HL_timing = (table_hi << 0x08) | 0x01
; .
; ↳return HL_timing, E_idx
@label=fn_timing_parameter_decode_helper
c$FBFD LD A,(HL)     ;
 $FBFE ADD A,$0C     ;
 $FC00 LD E,A        ;
 $FC01 LD D,$00      ;
 $FC03 LD HL,$FCA0   ;
 $FC06 ADD HL,DE     ;
 $FC07 LD H,(HL)     ;
 $FC08 LD L,$01      ;
 $FC0A RET           ;

; forced_interpreter_abort_path
;
; Forced interpreter abort path: unwind caller stack, re-enable interrupts, and
; return.
