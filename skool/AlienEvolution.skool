; ↳fn_process_transient_effect_queues_core(HL_queue=var_transient_queue_a_entries,
; DE_handler=fn_transient_queue_handler_core)
; .
; ↳fn_process_transient_effect_queues_core(HL_queue=var_transient_queue_b_entries,
; DE_handler=callback_queue_b_state_classifier)
