 $A8A8 INC HL        ;
 $A8A9 INC DE        ;
 $A8AA LD A,(DE)     ;
 $A8AB LD (HL),A     ;
 $A8AC INC DE        ;
 $A8AD DJNZ $A895    ;
 $A8AF RET           ;

