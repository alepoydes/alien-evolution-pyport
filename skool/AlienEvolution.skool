; scenario_intermission_beeper_stream_player_loop
;
; Scenario/intermission beeper stream player loop: run command interpreter
; 0xFC13 until termination condition from ROM poll.
;
; .
;
; 0xFBCD and 0xFBD3 are immediate HL words (default stream pointers) patched by
; scenario_pointer_seeding_core at 0xF161.
; .
; Args: none.
; .
; Returns: none.
; .
; def scenario_intermission_beeper_stream_player_loop():
; .
; ↳var_stream_ptr_a_lo = patch_stream_player_default_stream_a_ptr
; .
; ↳var_stream_ptr_c_lo = patch_stream_player_default_stream_b_ptr
; .
; ↳disable_interrupts()
; .
; ↳while True:
; .
; ↳↳core_command_interpreter_scenario_stream_engine()
; .
; ↳↳E_poll = rom_keyboard_input_poll_0x028E()
; .
; ↳↳if ((E_poll + 0x01) & 0xFF) != 0x00:
; .
; ↳↳↳break
; .
; ↳enable_interrupts()
@label=scenario_intermission_beeper_stream_player_loop
c$FBCC LD HL,$FD9B   ;
 $FBCF LD ($FBE7),HL ;
 $FBD2 LD HL,$FD9F   ;
 $FBD5 LD ($FBEB),HL ;
 $FBD8 DI            ;
*$FBD9 CALL $FC13    ;
 $FBDC CALL $028E    ;
 $FBDF INC E         ;
 $FBE0 JR Z,$FBD9    ;
 $FBE2 EI            ;
 $FBE3 RET           ;

; var_stream_interpreter_state
;
; Mutable interpreter state block: current command bytes and stream pointer
