; .
; Structure: interpreter context struct at 0xFBE4..0xFBEF: command bytes
; (0xFBE4-0xFBE6), stream pointers at 0xFBE7/0xFBE9/0xFBEB/0xFBED, and
; timing/control byte at 0xFBEF.
@label=var_stream_interpreter_state
