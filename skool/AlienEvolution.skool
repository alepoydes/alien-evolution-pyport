; abort_continue_gate_interpreter_loop
;
; Abort/continue gate for interpreter loop: ROM input check at 0x1F54, reset
; counters on abort request.
;
; .
;
; Args: none.
; .
; Returns: none.
; .
; def abort_continue_gate_interpreter_loop():
; .
; ↳disable_interrupts()
; .
; ↳C_continue = rom_keyboard_check_break_0x1F54()
; .
; ↳if not C_continue:
; .
; ↳↳var_runtime_scheduler_timer_hi = 0x00
; .
; ↳↳var_runtime_scheduler_timer_lo = 0x09
; .
; ↳enable_interrupts()
